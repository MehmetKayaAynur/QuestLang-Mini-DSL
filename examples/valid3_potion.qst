player hero: Player {
    level = 2;
    gold = 15;
    hasKey = false;
}

func canBuyPotion(p: Player): bool {
    return p.gold >= 10;
}

quest BuyPotion {
    if canBuyPotion(hero) {
        reward item "potion";
        log("Potion added to inventory");
    } else {
        log("Not enough gold");
    }
}